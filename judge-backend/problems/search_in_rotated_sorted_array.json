        {
            "input": "4 5 6 7 0 1 2\n0",
            "output": "4"
        },
        {
            "input": "4 5 6 7 0 1 2\n3",
            "output": "-1"
        },
        {
            "input": "1\n0",
            "output": "-1"
        }
